# ─── Family Tree Platform — Environment Variables ──────────
# Copy this file to .env and adjust as needed.

# ─── Database (Prisma) ────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# ─── Frontend Data Adapter ────────────────────────────────
# Options: rest (default) | mock | supabase
# "rest" connects to the backend API server (see server/index.ts)
VITE_DATA_ADAPTER=rest
VITE_API_BASE_URL=http://localhost:3001/api/v1

# ─── API Server Port ──────────────────────────────────────
API_PORT=3001

# ─── Auth ─────────────────────────────────────────────────
# JWT secret for signing auth tokens — CHANGE THIS in production!
# Generate with: openssl rand -hex 32
JWT_SECRET=dev-only-insecure-secret-change-me

# ─── Alternative Adapters (uncomment to use) ──────────────
# VITE_DATA_ADAPTER=mock
# VITE_DATA_ADAPTER=supabase
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here
